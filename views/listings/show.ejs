<% layout("./layout/boilerplate.ejs") -%>
<div class="col-8" style="margin-top: 100px">
  <div class="" style="width: 25rem">
    <h4><%= listing.title %></h4>
    <img
      src="<%= listing.image.url %>"
      class="card-img-top"
      alt="image"
      style="height: 200px; object-fit: cover"
    />

    <div class="card-body">
      <p><strong>Owner:</strong> <%= listing.owner.username %></p>
      <p><strong>Description:</strong> <%= listing.description %></p>
      <p>
        <strong>Price:</strong> ₹<%= listing.price.toLocaleString("en-IN") %>
      </p>
      <p><strong>Country:</strong> <%= listing.country %></p>
    </div>
<% if(currUser && listing.owner._id.equals(currUser._id)) { %>
    <div class="d-flex gap-2 mb-3 mx-3">
      <a href="/listings/<%= listing._id %>/edit" class="btn btn-primary">
        <i class="fa-solid fa-pen-to-square"></i>
      </a>

      <form action="/listings/<%= listing._id %>?_method=DELETE" method="post">
        <button class="btn btn-danger" type="submit">
          <i class="fa-solid fa-trash"></i>
        </button>
      </form>
    </div>
    <% } %>
    
  </div>
</div>
<% if(currUser) { %>
<!-- Review Form -->
<div class="mb-2 mt-4 col-8">
  <h4>Leave a Review</h4>
  <form
    action="/listings/<%=listing._id%>/reviews"
    method="post"
    novalidate
    class="needs-validation"
  >
    <div class="mb-3 col-4">
      <label class="form-label" for="rating"><b>Rating</b></label>
      <input
        type="range"
        name="review[rating]"
        id="rating"
        min="1"
        max="5"
        step="1"
        class="form-range"
      />
    </div>
    <div>
      <label class="form-label" for="comment"><b>Comment</b></label>
      <textarea
        name="review[comment]"
        id="comment"
        rows="5"
        cols="30"
        class="form-control"
        required
      ></textarea>
      <div class="invalid-feedback">
        Please enter a valid Comment
      </div>
    </div>
    <button class="mt-2 mb-4 btn btn-dark" type="submit">Submit Review</button>
  </form>
<% } %>

  <h4>All Reviews</h4>

    <div class="row">
      <% for (review of listing.reviews)  {%>
    <div class="card mb-3 me-3 col-5">
      <div class="card-body">
        <p class="card-text"><strong>Author:</strong> <%= review.author.username %></p>
        <p class="card-text"><%= review.comment %></p>
        <p class="card-text"><%= review.rating %> <i class="fa-solid fa-star" style="color: rgb(255, 219, 13); "></i></p>
        <form method="post" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
          <button class="btn btn-sm btn-danger"><i class="fa-solid fa-trash"></i></button>
        </form>
      </div>
    </div>
    <% } %>
    </div>
</div>
